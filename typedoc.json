{
  "entryPoints": ["src/index.ts", "types.ts"],
  "out": "docs",
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "markdown",
  "readme": "README.md",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeProtected": true,
  "hideBreadcrumbs": true,
  "hidePageTitle": true,
  "hideGenerator": true,
  "includeVersion": true,
  "lang": "en",
  "jsDocCompatibility": true,
  "cleanOutputDir": true
}

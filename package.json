{
  "name": "@pathmaker-digital/pmd-utilities",
  "version": "2.0.5",
  "description": "A lightweight and modular collection of utility functions for working with strings, dates, names, and more in TypeScript and JavaScript.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  },
  "scripts": {
    "build": "tsc",
    "push": "npm publish --access public",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crookedlungs/pmd-utilities.git"
  },
  "keywords": [
    "utilities",
    "currency",
    "formatting",
    "dates",
    "arrays",
    "tools",
    "auth",
    "hashing",
    "passwords",
    "async",
    "fetch"
  ],
  "author": "crookedlungs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/crookedlungs/pmd-utilities/issues"
  },
  "homepage": "https://github.com/crookedlungs/pmd-utilities#readme",
  "dependencies": {
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "typedoc": "^0.28.4",
    "typedoc-plugin-markdown": "^4.6.3"
  }
}
